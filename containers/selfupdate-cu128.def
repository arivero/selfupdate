Bootstrap: docker
From: pytorch/pytorch:2.11.0-cuda12.8-cudnn9-runtime

%labels
    Project selfupdate_lw
    Torch 2.11.0
    CUDA 12.8
    CUDNN 9

%environment
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export PIP_NO_CACHE_DIR=1
    export HF_HOME=/work/caches/huggingface
    export TRANSFORMERS_CACHE=/work/caches/huggingface
    export PYTORCH_ALLOC_CONF=expandable_segments:True
    export SELFUPDATE_CPU_THREADS=${SELFUPDATE_CPU_THREADS:-8}

%post
    set -eux
    python -m pip install --upgrade pip setuptools wheel
    python -m pip install \
        "transformers==5.12.1" \
        "accelerate==1.14.0" \
        "safetensors>=0.7" \
        "peft>=0.18" \
        "pyyaml" \
        "jiwer>=3" \
        "pandas" \
        "tabulate" \
        "matplotlib" \
        "tqdm" \
        "pytest"
    python - <<'PY'
import torch
assert torch.__version__.startswith("2.11.0"), torch.__version__
assert torch.version.cuda == "12.8", torch.version.cuda
print("torch", torch.__version__, "cuda", torch.version.cuda, "cudnn", torch.backends.cudnn.version())
PY

%runscript
    exec python "$@"

%test
    python - <<'PY'
import torch
import transformers
print("python ok")
print("torch", torch.__version__, "cuda", torch.version.cuda, "cudnn", torch.backends.cudnn.version())
print("transformers", transformers.__version__)
PY
